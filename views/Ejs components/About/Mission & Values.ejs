<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mission & Values | Best Home Care</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Remixicon Icons -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.3s ease-in-out',
                        'fade-in-up': 'fadeInUp 0.5s ease-out',
                        'fade-in-right': 'fadeInRight 0.5s ease-out',
                        'pulse-slow': 'pulse 3s infinite',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        fadeInUp: {
                            '0%': { opacity: '0', transform: 'translateY(20px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        },
                        fadeInRight: {
                            '0%': { opacity: '0', transform: 'translateX(-20px)' },
                            '100%': { opacity: '1', transform: 'translateX(0)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Theme transition for all elements */
        * {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, fill 0.3s ease, stroke 0.3s ease, box-shadow 0.3s ease;
        }
        
        /* Better dark mode contrast */
        .dark body {
            color-scheme: dark;
        }

        /* Value card hover effect */
        .value-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .value-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
        .dark .value-card:hover {
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
        }

        /* Hero image overlay - matches header */
        .hero-overlay {
            background: linear-gradient(135deg, rgba(30, 64, 175, 0.85) 0%, rgba(37, 99, 235, 0.75) 50%, rgba(59, 130, 246, 0.7) 100%);
        }
        .dark .hero-overlay {
            background: linear-gradient(135deg, rgba(30, 58, 138, 0.9) 0%, rgba(30, 64, 175, 0.85) 50%, rgba(37, 99, 235, 0.8) 100%);
        }

        /* Principle card styling */
        .principle-card {
            transition: all 0.3s ease;
        }
        .principle-card:hover {
            transform: scale(1.02);
        }

        /* CARE word styling */
        .care-letter {
            display: inline-block;
            transition: all 0.3s ease;
        }
        .care-letter:hover {
            transform: scale(1.1);
            color: #2563eb;
        }

        /* Commitment section highlight */
        .commitment-badge {
            transition: all 0.3s ease;
        }
        .commitment-badge:hover {
            transform: translateY(-3px);
        }

        /* Child safety icon animation */
        .safety-icon {
            animation: pulse 2s infinite;
        }
    </style>
</head>
<%- include('../header.ejs') %> 
<br>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen font-sans antialiased">

   

    <!-- Hero Section with Unsplash Image - Compassionate care team -->
    <section class="relative w-full h-96 lg:h-[500px] overflow-hidden">
        <!-- Unsplash/Pexels Image: Diverse care team supporting client -->
        <img src="https://images.pexels.com/photos/7551610/pexels-photo-7551610.jpeg?auto=compress&cs=tinysrgb&w=1600" 
             alt="Compassionate care team supporting client" 
             class="absolute inset-0 w-full h-full object-cover object-center"
             loading="lazy">
        <!-- Blue Gradient Overlay - matches header theme -->
        <div class="hero-overlay absolute inset-0"></div>
        
        <!-- Hero Content -->
        <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4 animate-fade-in-up">
            <div class="inline-flex items-center justify-center p-3 bg-white/20 backdrop-blur-sm rounded-full mb-6">
                <i class="ri-heart-pulse-fill text-white text-3xl"></i>
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 drop-shadow-lg">
                Mission & Values
            </h1>
            <div class="w-24 h-1 bg-white rounded-full mb-6"></div>
            <p class="text-white text-xl md:text-2xl max-w-3xl drop-shadow-md font-medium">
                Compassion · Assistance · Reassurance · Empathy
            </p>
        </div>
    </section>

    <!-- The CARE Philosophy Section -->
    <section class="container mx-auto px-4 py-16 md:py-20">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-12">
                <div class="inline-flex items-center justify-center p-2 bg-blue-100 dark:bg-blue-900/30 rounded-full mb-6">
                    <i class="ri-hearts-line text-blue-600 dark:text-blue-400 text-2xl mx-2"></i>
                </div>
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-800 dark:text-white mb-6">
                    Our <span class="text-blue-600 dark:text-blue-400">CARE</span> Philosophy
                </h2>
                <p class="text-gray-600 dark:text-gray-300 text-lg md:text-xl leading-relaxed max-w-4xl mx-auto">
                    At BHC, we resolutely believe that <span class="font-bold text-blue-600 dark:text-blue-400">CARE</span> is all about 
                </p>
            </div>

            <!-- CARE Letters Grid -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
                <!-- C - Compassion -->
                <div class="principle-card bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-md border border-gray-100 dark:border-gray-700 text-center">
                    <div class="text-5xl md:text-6xl font-bold text-blue-600 dark:text-blue-400 mb-4 care-letter">C</div>
                    <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3">Compassion</h3>
                    <p class="text-gray-600 dark:text-gray-400">Deep awareness and sympathy for another's suffering</p>
                </div>

                <!-- A - Assistance -->
                <div class="principle-card bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-md border border-gray-100 dark:border-gray-700 text-center">
                    <div class="text-5xl md:text-6xl font-bold text-blue-600 dark:text-blue-400 mb-4 care-letter">A</div>
                    <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3">Assistance</h3>
                    <p class="text-gray-600 dark:text-gray-400">Helping hands for daily needs and goals</p>
                </div>

                <!-- R - Reassurance -->
                <div class="principle-card bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-md border border-gray-100 dark:border-gray-700 text-center">
                    <div class="text-5xl md:text-6xl font-bold text-blue-600 dark:text-blue-400 mb-4 care-letter">R</div>
                    <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3">Reassurance</h3>
                    <p class="text-gray-600 dark:text-gray-400">Peace of mind for clients and their families</p>
                </div>

                <!-- E - Empathy -->
                <div class="principle-card bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-md border border-gray-100 dark:border-gray-700 text-center">
                    <div class="text-5xl md:text-6xl font-bold text-blue-600 dark:text-blue-400 mb-4 care-letter">E</div>
                    <h3 class="text-xl font-bold text-gray-800 dark:text-white mb-3">Empathy</h3>
                    <p class="text-gray-600 dark:text-gray-400">Understanding and sharing feelings of others</p>
                </div>
            </div>

            <!-- Extended Description -->
            <div class="bg-blue-50 dark:bg-gray-800/50 rounded-3xl p-8 md:p-10 text-center">
                <p class="text-gray-700 dark:text-gray-300 text-lg md:text-xl leading-relaxed">
                    Our hand-picked crew of caregivers has these qualities deeply rooted in their desire to serve and support. If you are struggling with caring for an aging or ailing loved one, trust us at BHC to take the onus on our shoulders. We are a team of enthusiastic people passionate about making a difference in people's lives by providing quality care and support with complete involvement and an innate sense of connecting.
                </p>
            </div>
        </div>
    </section>

    <!-- Who We Serve Section -->
    <section class="bg-white dark:bg-gray-800 py-16 md:py-20">
        <div class="container mx-auto px-4">
            <div class="flex flex-col lg:flex-row items-center gap-12">
                <!-- Image Side -->
                <div class="lg:w-1/2 animate-fade-in-right">
                    <div class="relative rounded-3xl overflow-hidden shadow-2xl">
                        <img src="https://images.pexels.com/photos/6647026/pexels-photo-6647026.jpeg?auto=compress&cs=tinysrgb&w=1600" 
                             alt="Caregiver supporting client" 
                             class="w-full h-auto object-cover">
                        <div class="absolute inset-0 bg-gradient-to-t from-blue-600/20 to-transparent"></div>
                    </div>
                </div>
                
                <!-- Content Side -->
                <div class="lg:w-1/2 space-y-6 animate-fade-in-up">
                    <div class="inline-flex items-center p-2 bg-blue-100 dark:bg-blue-900/30 rounded-full">
                        <i class="ri-group-line text-blue-600 dark:text-blue-400 mr-2"></i>
                        <span class="text-blue-600 dark:text-blue-400 font-medium">For Everyone Who Needs Support</span>
                    </div>
                    <h3 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white">
                        We're Here for You <span class="text-blue-600 dark:text-blue-400">Whatever Your Needs</span>
                    </h3>
                    <p class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed">
                        Whether you are an older person looking for a helping hand with daily necessities, or a younger person with a disability looking for support to accomplish your goals, we can customize a support solution just for you.
                    </p>
                    <p class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed">
                        Our services are suitable for people of all ages and abilities who would like to receive extra support to get the most out of life. Our team includes care coordinators, registered nurses, and support workers.
                    </p>
                    
                    <!-- Team roles badges -->
                    <div class="flex flex-wrap gap-3 pt-4">
                        <span class="bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-4 py-2 rounded-full text-sm font-medium">Care Coordinators</span>
                        <span class="bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-4 py-2 rounded-full text-sm font-medium">Registered Nurses</span>
                        <span class="bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-4 py-2 rounded-full text-sm font-medium">Support Workers</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission & Vision Side by Side -->
    <section class="container mx-auto px-4 py-16 md:py-20">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Mission Card -->
            <div class="value-card bg-gradient-to-br from-blue-600 to-blue-700 dark:from-blue-800 dark:to-blue-900 rounded-3xl p-10 text-white shadow-xl">
                <div class="w-16 h-16 bg-white/20 backdrop-blur-sm rounded-2xl flex items-center justify-center mb-6">
                    <i class="ri-flag-line text-3xl text-white"></i>
                </div>
                <h2 class="text-3xl font-bold mb-4">Our Mission</h2>
                <p class="text-white/90 text-lg leading-relaxed">
                    At Best of Home Care, our mission is simple: We treat every client like a member of our own family. We go the extra mile to ensure that care is provided the right way, at the right time, and with the utmost attention to detail. Your well-being is our top priority, and we're here to support you every step of the way.
                </p>
                <div class="mt-6 flex items-center">
                    <i class="ri-heart-3-fill text-white/80 mr-2"></i>
                    <span class="text-white/80">Family-first approach</span>
                </div>
            </div>

            <!-- Vision Card -->
            <div class="value-card bg-white dark:bg-gray-800 rounded-3xl p-10 shadow-xl border border-gray-100 dark:border-gray-700">
                <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900/40 rounded-2xl flex items-center justify-center mb-6">
                    <i class="ri-eye-line text-3xl text-blue-600 dark:text-blue-400"></i>
                </div>
                <h2 class="text-3xl font-bold text-gray-800 dark:text-white mb-4">Our Vision</h2>
                <p class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed">
                    We envision a care service that truly treats clients with the dignity and compassion they deserve. Our approach to CARE is built on four core principles: Compassion, Assistance, Reassurance, and Empathy. We believe caregivers bring more than just skills — they bring a heart for service, making a meaningful difference in every life they touch.
                </p>
                <div class="mt-6 grid grid-cols-2 gap-2">
                    <span class="text-blue-600 dark:text-blue-400 font-medium">• Compassion</span>
                    <span class="text-blue-600 dark:text-blue-400 font-medium">• Assistance</span>
                    <span class="text-blue-600 dark:text-blue-400 font-medium">• Reassurance</span>
                    <span class="text-blue-600 dark:text-blue-400 font-medium">• Empathy</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Our Values Section -->
    <section class="bg-blue-50 dark:bg-gray-800/50 py-16 md:py-20">
        <div class="container mx-auto px-4">
            <div class="text-center mb-16">
                <div class="inline-flex items-center justify-center p-2 bg-blue-100 dark:bg-blue-900/30 rounded-full mb-6">
                    <i class="ri-star-smile-line text-blue-600 dark:text-blue-400 text-2xl mx-2"></i>
                </div>
                <h2 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white mb-4">
                    Our Core <span class="text-blue-600 dark:text-blue-400">Values</span>
                </h2>
                <p class="text-gray-600 dark:text-gray-300 text-lg max-w-2xl mx-auto">
                    At BHC, our values guide everything we do. They ensure that every interaction, every service, and every caregiver reflects the high standard of care you deserve.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Value 1: Accountability -->
                <div class="value-card bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-md border border-gray-100 dark:border-gray-700">
                    <div class="w-14 h-14 bg-blue-100 dark:bg-blue-900/40 rounded-xl flex items-center justify-center mb-4">
                        <i class="ri-shield-check-line text-2xl text-blue-600 dark:text-blue-400"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-3">Accountability</h3>
                    <p class="text-gray-600 dark:text-gray-400">
                        We believe in taking responsibility for the care we provide. Our caregivers are committed to doing their best for every client and their families, always acting with integrity and independence.
                    </p>
                </div>

                <!-- Value 2: Integrity -->
                <div class="value-card bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-md border border-gray-100 dark:border-gray-700">
                    <div class="w-14 h-14 bg-blue-100 dark:bg-blue-900/40 rounded-xl flex items-center justify-center mb-4">
                        <i class="ri-balance-line text-2xl text-blue-600 dark:text-blue-400"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-3">Integrity</h3>
                    <p class="text-gray-600 dark:text-gray-400">
                        Our caregivers operate with a strict moral and ethical code. Their positive attitude and dedication ensure that every day spent with a client is meaningful, compassionate, and focused on their well-being.
                    </p>
                </div>

                <!-- Value 3: Respect -->
                <div class="value-card bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-md border border-gray-100 dark:border-gray-700">
                    <div class="w-14 h-14 bg-blue-100 dark:bg-blue-900/40 rounded-xl flex items-center justify-center mb-4">
                        <i class="ri-hand-heart-line text-2xl text-blue-600 dark:text-blue-400"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-gray-800 dark:text-white mb-3">Respect</h3>
                    <p class="text-gray-600 dark:text-gray-400">
                        Respect is at the heart of everything we do. Whether it's respecting our clients' wishes, their home, or our fellow team members, we believe mutual respect creates an environment of care that leads to exceptional service and satisfaction.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Child Safety Commitment Section -->
    <section class="container mx-auto px-4 py-16 md:py-20">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-12">
                <div class="inline-flex items-center justify-center p-2 bg-blue-100 dark:bg-blue-900/30 rounded-full mb-6">
                    <i class="ri-shield-star-line text-blue-600 dark:text-blue-400 text-2xl mx-2"></i>
                </div>
                <h2 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white mb-4">
                    Our Commitment to <span class="text-blue-600 dark:text-blue-400">Child Safety</span>
                </h2>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                <!-- Left Column - Main Commitment -->
                <div class="space-y-6 animate-fade-in-right">
                    <div class="bg-white dark:bg-gray-800 rounded-3xl p-8 shadow-xl border border-gray-100 dark:border-gray-700">
                        <div class="flex items-center mb-6">
                            <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/40 rounded-full flex items-center justify-center mr-4">
                                <i class="ri-heart-2-fill text-2xl text-blue-600 dark:text-blue-400 safety-icon"></i>
                            </div>
                            <h3 class="text-2xl font-bold text-gray-800 dark:text-white">Safe, Happy, Empowered</h3>
                        </div>
                        <p class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed mb-6">
                            At Best of Homecare, we are dedicated to ensuring that children are safe, happy, and empowered. We believe every child deserves to grow in a safe and supportive environment, and we are fully committed to their safety, participation, and empowerment.
                        </p>
                        <div class="bg-red-50 dark:bg-red-900/20 border-l-4 border-red-500 p-4 rounded-r-xl">
                            <p class="text-red-700 dark:text-red-300 font-semibold flex items-center">
                                <i class="ri-alert-line mr-2 text-xl"></i>
                                We have a zero-tolerance policy for child abuse.
                            </p>
                        </div>
                    </div>

                    <div class="bg-blue-50 dark:bg-gray-800/50 rounded-2xl p-6">
                        <p class="text-gray-700 dark:text-gray-300">
                            Any allegations or concerns will be taken seriously and handled according to our strict policies and procedures. If we ever have concerns about a child's safety, we have legal and moral obligations to contact the appropriate authorities, and we do so without hesitation.
                        </p>
                    </div>
                </div>

                <!-- Right Column - Prevention & Cultural Safety -->
                <div class="space-y-6 animate-fade-in-up">
                    <!-- Prevention Card -->
                    <div class="value-card bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-md">
                        <div class="flex items-center mb-4">
                            <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/40 rounded-full flex items-center justify-center mr-3">
                                <i class="ri-shield-keyhole-line text-xl text-blue-600 dark:text-blue-400"></i>
                            </div>
                            <h4 class="text-xl font-bold text-gray-800 dark:text-white">Prevention & Recruitment</h4>
                        </div>
                        <p class="text-gray-600 dark:text-gray-400">
                            Our commitment extends to preventing child abuse and identifying potential risks early. We take every step to reduce these risks through our thorough human resources and recruitment practices, ensuring that our staff, management, and contractors are well-vetted and trained.
                        </p>
                    </div>

                    <!-- Cultural Safety Card -->
                    <div class="value-card bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-md">
                        <div class="flex items-center mb-4">
                            <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/40 rounded-full flex items-center justify-center mr-3">
                                <i class="ri-global-line text-xl text-blue-600 dark:text-blue-400"></i>
                            </div>
                            <h4 class="text-xl font-bold text-gray-800 dark:text-white">Cultural Safety</h4>
                        </div>
                        <p class="text-gray-600 dark:text-gray-400">
                            We also prioritise the cultural safety of all children, including Aboriginal children, children from diverse cultural and linguistic backgrounds, and those with disabilities. Our ongoing training for staff ensures they are equipped to recognize and address child safety concerns effectively.
                        </p>
                    </div>

                    <!-- Policies Card -->
                    <div class="value-card bg-white dark:bg-gray-800 rounded-2xl p-6 shadow-md">
                        <div class="flex items-center mb-4">
                            <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/40 rounded-full flex items-center justify-center mr-3">
                                <i class="ri-file-list-line text-xl text-blue-600 dark:text-blue-400"></i>
                            </div>
                            <h4 class="text-xl font-bold text-gray-800 dark:text-white">Specific Policies</h4>
                        </div>
                        <p class="text-gray-600 dark:text-gray-400">
                            Additionally, we have specific policies and procedures in place to support these commitments, providing a safe environment for all children under our care.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Child Safety Badges -->
            <div class="flex flex-wrap justify-center gap-4 mt-12">
                <span class="commitment-badge bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-5 py-2.5 rounded-full text-sm font-medium flex items-center">
                    <i class="ri-shield-line mr-2"></i> Zero Tolerance
                </span>
                <span class="commitment-badge bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-5 py-2.5 rounded-full text-sm font-medium flex items-center">
                    <i class="ri-team-line mr-2"></i> Cultural Safety
                </span>
                <span class="commitment-badge bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-5 py-2.5 rounded-full text-sm font-medium flex items-center">
                    <i class="ri-file-search-line mr-2"></i> Vetted Staff
                </span>
                <span class="commitment-badge bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 px-5 py-2.5 rounded-full text-sm font-medium flex items-center">
                    <i class="ri-mental-health-line mr-2"></i> Ongoing Training
                </span>
            </div>
        </div>
    </section>

    <!-- Call to Action - Join Us in Making a Difference -->
    <section class="bg-gradient-to-r from-blue-600 to-blue-800 dark:from-blue-900 dark:to-blue-950 py-16 text-white">
        <div class="container mx-auto px-4 text-center">
            <div class="max-w-3xl mx-auto">
                <i class="ri-heart-pulse-fill text-5xl mb-4 inline-block text-white/90"></i>
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Live Our Values Every Day</h2>
                <p class="text-xl md:text-2xl leading-relaxed mb-8 text-white/90">
                    If you share our passion for compassionate care and want to make a real difference, we'd love to hear from you.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="#" class="btn-hover bg-white text-blue-700 font-bold px-8 py-4 rounded-full shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center">
                        <i class="ri-briefcase-line mr-2 text-xl"></i>
                        Join Our Team
                    </a>
                    <a href="#" class="btn-hover bg-transparent border-2 border-white text-white font-bold px-8 py-4 rounded-full hover:bg-white/10 transition-all duration-300 flex items-center justify-center">
                        <i class="ri-phone-line mr-2 text-xl"></i>
