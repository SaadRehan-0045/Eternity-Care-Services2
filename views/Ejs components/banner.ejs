<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Best of Home Care - Top Contact Bar</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.1/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.3s ease-in-out',
                        'slide-down': 'slideDown 0.3s ease-out',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        slideDown: {
                            '0%': { transform: 'translateY(-100%)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Theme transition */
        * {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
        }
        
        /* Top bar background - slightly different shade to distinguish from header */
        .top-bar-bg {
            background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
        }
        
        .dark .top-bar-bg {
            background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
        }
        
        /* Contact info hover effects */
        .contact-info:hover {
            transform: translateX(3px);
        }

        /* Sticky banner - appears below header */
        .sticky-banner {
            position: sticky;
            top: 0;
            z-index: 999;
            width: 100%;
        }

        /* Adjust for header height - header is 80px approx, banner starts after it */
        .header-offset {
            margin-top: 0;
        }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen">
    
    <!-- Top Contact Bar - Sticky, appears below header -->
    <div class="static-banner top-bar-bg text-white animate-slide-down shadow-sm">
        <!-- Desktop Version -->
        <div class="hidden lg:block">
            <div class="container mx-auto px-4">
                <div class="flex items-center justify-center py-2">
                    <!-- Contact Info - Centered with slightly smaller text -->
                    <div class="flex items-center space-x-6">
                        <!-- Phone -->
                        <a href="tel:1300513309" class="contact-info flex items-center hover:text-blue-200 transition-all duration-200 group">
                            <div class="w-7 h-7 bg-white/20 rounded-full flex items-center justify-center mr-2 group-hover:bg-white/30">
                                <i class="ri-phone-line text-xs"></i>
                            </div>
                            <span class="font-medium text-sm">1300 513 309</span>
                            <i class="ri-external-link-line ml-2 text-xs opacity-0 group-hover:opacity-100 transition-opacity"></i>
                        </a>
                        
                        <!-- Email -->
                        <a href="mailto:admin@bestofhomecare.com.au" class="contact-info flex items-center hover:text-blue-200 transition-all duration-200 group">
                            <div class="w-7 h-7 bg-white/20 rounded-full flex items-center justify-center mr-2 group-hover:bg-white/30">
                                <i class="ri-mail-line text-xs"></i>
                            </div>
                            <span class="font-medium text-sm">admin@bestofhomecare.com.au</span>
                            <i class="ri-external-link-line ml-2 text-xs opacity-0 group-hover:opacity-100 transition-opacity"></i>
                        </a>
                        
                        <!-- Location - with short version on smaller screens -->
                        <div class="contact-info flex items-center group">
                            <div class="w-7 h-7 bg-white/20 rounded-full flex items-center justify-center mr-2 group-hover:bg-white/30">
                                <i class="ri-map-pin-line text-xs"></i>
                            </div>
                            <span class="font-medium text-sm hidden xl:inline">1/43 Rainier Crescent, Clyde North VIC 3978</span>
                            <span class="font-medium text-sm inline xl:hidden">Clyde North VIC</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Mobile Version - Improved with better spacing -->
        <div class="lg:hidden">
            <div class="container mx-auto px-4 py-2">
                <!-- 3 Icons with labels -->
                <div class="flex items-center justify-center space-x-6">
                    <!-- Phone -->
                    <a href="tel:1300513309" class="flex flex-col items-center hover:text-blue-200 transition-all duration-200">
                        <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center hover:bg-white/30">
                            <i class="ri-phone-line text-sm"></i>
                        </div>
                        <span class="text-[10px] mt-1">Call</span>
                    </a>
                    
                    <!-- Location -->
                    <div class="flex flex-col items-center">
                        <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center">
                            <i class="ri-map-pin-line text-sm"></i>
                        </div>
                        <span class="text-[10px] mt-1">Location</span>
                    </div>
                    
                    <!-- Email -->
                    <a href="mailto:admin@bestofhomecare.com.au" class="flex flex-col items-center hover:text-blue-200 transition-all duration-200">
                        <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center hover:bg-white/30">
                            <i class="ri-mail-line text-sm"></i>
                        </div>
                        <span class="text-[10px] mt-1">Email</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Banner specific functionality
        (function() {
            'use strict';

            // Add click-to-copy functionality for phone numbers
            document.querySelectorAll('a[href^="tel:"]').forEach(phoneLink => {
                phoneLink.addEventListener('click', (e) => {
                    e.preventDefault();
                    const phoneNumber = phoneLink.href.replace('tel:', '');
                    const feedback = document.createElement('div');
                    feedback.className = 'fixed top-24 left-1/2 transform -translate-x-1/2 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg z-[1002] animate-fade-in text-sm';
                    feedback.textContent = `Copied ${phoneNumber} to clipboard`;
                    
                    navigator.clipboard.writeText(phoneNumber).then(() => {
                        document.body.appendChild(feedback);
                        setTimeout(() => {
                            feedback.remove();
                        }, 2000);
                    }).catch(() => {
                        // Fallback if clipboard fails
                        alert(`Phone number: ${phoneNumber}`);
                    });
                });
            });

            // Add hover effects for contact info
            document.querySelectorAll('.contact-info').forEach(info => {
                info.addEventListener('mouseenter', () => {
                    const icon = info.querySelector('.ri-external-link-line');
                    if (icon) icon.style.opacity = '1';
                });
                
                info.addEventListener('mouseleave', () => {
                    const icon = info.querySelector('.ri-external-link-line');
                    if (icon) icon.style.opacity = '0';
                });
            });

            // Shadow on scroll
            window.addEventListener('scroll', () => {
                const banner = document.querySelector('.sticky-banner');
                if (window.scrollY > 10) {
                    banner.classList.add('shadow-md');
                } else {
                    banner.classList.remove('shadow-md');
                }
            });
        })();
    </script>
</body>
</html>