<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BHC Services Carousel | Best Home Care</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Remixicon Icons -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.6s ease-in-out',
                        'slide-up': 'slideUp 0.6s ease-out',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Theme transition */
        * {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
        }
        
        /* Carousel text overlay gradient */
        .carousel-overlay {
            background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.4) 50%, transparent 100%);
        }
        
        /* Slide content animation */
        .slide-content {
            animation: slideUp 0.8s ease-out;
        }

        /* Full width carousel */
        .full-width-carousel {
            width: 100vw;
            position: relative;
            left: 50%;
            right: 50%;
            margin-left: -50vw;
            margin-right: -50vw;
        }

        /* Mobile-specific adjustments */
        @media (max-width: 640px) {
            .carousel-text-container {
                padding: 1.5rem !important;
                width: 90% !important;
            }
            .carousel-title {
                font-size: 1.8rem !important;
                line-height: 1.2 !important;
            }
            .carousel-description {
                font-size: 1rem !important;
                line-height: 1.4 !important;
                margin-bottom: 0.5rem !important;
            }
        }

        /* Small mobile devices */
        @media (max-width: 380px) {
            .carousel-text-container {
                padding: 1rem !important;
                width: 95% !important;
            }
            .carousel-title {
                font-size: 1.5rem !important;
            }
            .carousel-description {
                font-size: 0.9rem !important;
            }
        }
    </style>
</head>

<!-- <br> -->

<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen overflow-x-hidden">

    <!-- Full Width Carousel Section -->
    <div class="full-width-carousel">
        <!-- Carousel Section -->
        <div id="bhc-services-carousel" class="relative w-full" data-bhc-carousel="slide">
            <!-- Carousel wrapper -->
            <div class="relative h-[400px] sm:h-[450px] md:h-[500px] lg:h-[550px] xl:h-[600px] overflow-hidden">
                
                <!-- Item 1 - NDIS Services -->
                <div class="hidden duration-700 ease-in-out" data-bhc-carousel-item>
                    <img src="https://images.pexels.com/photos/6647026/pexels-photo-6647026.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2" 
                         class="absolute block w-full h-full object-cover" 
                         alt="NDIS support services">
                    <!-- Dark overlay for text readability -->
                    <div class="carousel-overlay absolute inset-0"></div>
                    <!-- Text Content -->
                    <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-6 md:p-8 lg:p-10 xl:p-12 text-white carousel-text-container">
                        <div class="max-w-7xl mx-auto slide-content">
                            <span class="inline-block bg-blue-600 text-white text-xs sm:text-sm font-semibold px-3 sm:px-4 py-1.5 sm:py-2 rounded-full mb-2 sm:mb-3">NDIS Services</span>
                            <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-2 sm:mb-3 carousel-title">One-Stop Provider For All Your NDIS Needs</h2>
                            <p class="text-sm sm:text-base md:text-lg lg:text-xl text-gray-100 mb-2 sm:mb-3 carousel-description max-w-3xl">BHC provides tailored NDIS services, including personal care, specialised housing, and gardening assistance. Your trusted partner for high-quality, individualised support.</p>
                        </div>
                    </div>
                </div>
                
                <!-- Item 2 - Aged Care -->
                <div class="hidden duration-700 ease-in-out" data-bhc-carousel-item>
                    <img src="https://images.pexels.com/photos/6646917/pexels-photo-6646917.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2" 
                         class="absolute block w-full h-full object-cover" 
                         alt="Aged care services">
                    <!-- Dark overlay for text readability -->
                    <div class="carousel-overlay absolute inset-0"></div>
                    <!-- Text Content -->
                    <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-6 md:p-8 lg:p-10 xl:p-12 text-white carousel-text-container">
                        <div class="max-w-7xl mx-auto slide-content">
                            <span class="inline-block bg-green-600 text-white text-xs sm:text-sm font-semibold px-3 sm:px-4 py-1.5 sm:py-2 rounded-full mb-2 sm:mb-3">Aged Care</span>
                            <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-2 sm:mb-3 carousel-title">Compassionate Aged Care, Designed For You</h2>
                            <p class="text-sm sm:text-base md:text-lg lg:text-xl text-gray-100 mb-2 sm:mb-3 carousel-description max-w-3xl">Enjoy the comfort and security of personalised aged care services. We help you or your loved ones live independently with dignity and respect.</p>
                        </div>
                    </div>
                </div>
                
                <!-- Item 3 - Day Programs -->
                <div class="hidden duration-700 ease-in-out" data-bhc-carousel-item>
                    <img src="https://images.pexels.com/photos/7653567/pexels-photo-7653567.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2" 
                         class="absolute block w-full h-full object-cover" 
                         alt="Day programs activities">
                    <!-- Dark overlay for text readability -->
                    <div class="carousel-overlay absolute inset-0"></div>
                    <!-- Text Content -->
                    <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-6 md:p-8 lg:p-10 xl:p-12 text-white carousel-text-container">
                        <div class="max-w-7xl mx-auto slide-content">
                            <span class="inline-block bg-purple-600 text-white text-xs sm:text-sm font-semibold px-3 sm:px-4 py-1.5 sm:py-2 rounded-full mb-2 sm:mb-3">Day Programs</span>
                            <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-2 sm:mb-3 carousel-title">Engaging Day Programs With Weekly Activities</h2>
                            <p class="text-sm sm:text-base md:text-lg lg:text-xl text-gray-100 mb-2 sm:mb-3 carousel-description max-w-3xl">Stay active, learn new skills, and connect with others through our fun and engaging day programs, designed for all abilities.</p>
                        </div>
                    </div>
                </div>
                
                <!-- Item 4 - Independent Living -->
                <div class="hidden duration-700 ease-in-out" data-bhc-carousel-item>
                    <img src="https://images.pexels.com/photos/280229/pexels-photo-280229.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2" 
                         class="absolute block w-full h-full object-cover" 
                         alt="Independent living support">
                    <!-- Dark overlay for text readability -->
                    <div class="carousel-overlay absolute inset-0"></div>
                    <!-- Text Content -->
                    <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-6 md:p-8 lg:p-10 xl:p-12 text-white carousel-text-container">
                        <div class="max-w-7xl mx-auto slide-content">
                            <span class="inline-block bg-amber-600 text-white text-xs sm:text-sm font-semibold px-3 sm:px-4 py-1.5 sm:py-2 rounded-full mb-2 sm:mb-3">Independent Living</span>
                            <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-2 sm:mb-3 carousel-title">Supporting Independent Living With Compassion</h2>
                            <p class="text-sm sm:text-base md:text-lg lg:text-xl text-gray-100 mb-2 sm:mb-3 carousel-description max-w-3xl">Whether you need long-term support or short-term recovery care, we're here to help you live independently with confidence.</p>
                        </div>
                    </div>
                </div>
                
                <!-- Item 5 - Regain Independence -->
                <div class="hidden duration-700 ease-in-out" data-bhc-carousel-item>
                    <img src="https://images.pexels.com/photos/6647026/pexels-photo-6647026.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2" 
                         class="absolute block w-full h-full object-cover" 
                         alt="Recovery and rehabilitation">
                    <!-- Dark overlay for text readability -->
                    <div class="carousel-overlay absolute inset-0"></div>
                    <!-- Text Content -->
                    <div class="absolute bottom-0 left-0 right-0 p-4 sm:p-6 md:p-8 lg:p-10 xl:p-12 text-white carousel-text-container">
                        <div class="max-w-7xl mx-auto slide-content">
                            <span class="inline-block bg-red-600 text-white text-xs sm:text-sm font-semibold px-3 sm:px-4 py-1.5 sm:py-2 rounded-full mb-2 sm:mb-3">Recovery Support</span>
                            <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold mb-2 sm:mb-3 carousel-title">Regain Independence With Personalised Support</h2>
                            <p class="text-sm sm:text-base md:text-lg lg:text-xl text-gray-100 mb-2 sm:mb-3 carousel-description max-w-3xl">Recover with confidence and the right support. Our care services assist with mobility, rehabilitation, and daily tasks to help you stay independent.</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Slider indicators -->
            <div class="absolute z-30 flex -translate-x-1/2 bottom-3 sm:bottom-5 left-1/2 space-x-2 sm:space-x-3 rtl:space-x-reverse">
                <button type="button" class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-white/50 hover:bg-white/80 transition-colors duration-300" aria-current="true" aria-label="Slide 1" data-bhc-carousel-slide-to="0"></button>
                <button type="button" class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-white/50 hover:bg-white/80 transition-colors duration-300" aria-current="false" aria-label="Slide 2" data-bhc-carousel-slide-to="1"></button>
                <button type="button" class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-white/50 hover:bg-white/80 transition-colors duration-300" aria-current="false" aria-label="Slide 3" data-bhc-carousel-slide-to="2"></button>
                <button type="button" class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-white/50 hover:bg-white/80 transition-colors duration-300" aria-current="false" aria-label="Slide 4" data-bhc-carousel-slide-to="3"></button>
                <button type="button" class="w-2 h-2 sm:w-3 sm:h-3 rounded-full bg-white/50 hover:bg-white/80 transition-colors duration-300" aria-current="false" aria-label="Slide 5" data-bhc-carousel-slide-to="4"></button>
            </div>
            
            <!-- Slider controls -->
            <button type="button" class="absolute top-1/2 -translate-y-1/2 left-2 sm:left-4 z-30 flex items-center justify-center w-8 h-8 sm:w-10 sm:h-10 md:w-12 md:h-12 rounded-full bg-black/40 dark:bg-gray-800/40 hover:bg-black/60 dark:hover:bg-gray-800/60 backdrop-blur-sm transition-all duration-300 group focus:outline-none" data-bhc-carousel-prev>
                <i class="ri-arrow-left-s-line text-white text-xl sm:text-2xl"></i>
                <span class="sr-only">Previous</span>
            </button>
            <button type="button" class="absolute top-1/2 -translate-y-1/2 right-2 sm:right-4 z-30 flex items-center justify-center w-8 h-8 sm:w-10 sm:h-10 md:w-12 md:h-12 rounded-full bg-black/40 dark:bg-gray-800/40 hover:bg-black/60 dark:hover:bg-gray-800/60 backdrop-blur-sm transition-all duration-300 group focus:outline-none" data-bhc-carousel-next>
                <i class="ri-arrow-right-s-line text-white text-xl sm:text-2xl"></i>
                <span class="sr-only">Next</span>
            </button>
        </div>
    </div>

    <!-- Carousel JavaScript - Self-contained and isolated -->
    <script>
        (function() {
            'use strict';
            
            // Wait for DOM to be fully loaded
            function initCarousel() {
                // Get carousel elements with unique BHC prefix
                const carousel = document.getElementById('bhc-services-carousel');
                if (!carousel) {
                    console.log('BHC Carousel: Element not found');
                    return;
                }
                
                const items = document.querySelectorAll('[data-bhc-carousel-item]');
                const indicators = document.querySelectorAll('[data-bhc-carousel-slide-to]');
                const prevButton = document.querySelector('[data-bhc-carousel-prev]');
                const nextButton = document.querySelector('[data-bhc-carousel-next]');
                
                if (!items.length) {
                    console.log('BHC Carousel: No items found');
                    return;
                }
                
                let currentIndex = 0;
                let interval;
                let isTransitioning = false;

                // Show first item
                items[0].classList.remove('hidden');
                if (indicators[0]) {
                    indicators[0].setAttribute('aria-current', 'true');
                }

                // Function to show slide at index
                function showSlide(index) {
                    if (isTransitioning) return;
                    isTransitioning = true;
                    
                    if (index < 0) index = items.length - 1;
                    if (index >= items.length) index = 0;
                    
                    items.forEach((item, i) => {
                        item.classList.add('hidden');
                        if (i === index) {
                            item.classList.remove('hidden');
                            // Add animation class
                            const content = item.querySelector('.slide-content');
                            if (content) {
                                content.style.animation = 'none';
                                content.offsetHeight; // Trigger reflow
                                content.style.animation = 'slideUp 0.8s ease-out';
                            }
                        }
                    });
                    
                    indicators.forEach((indicator, i) => {
                        if (i === index) {
                            indicator.setAttribute('aria-current', 'true');
                        } else {
                            indicator.setAttribute('aria-current', 'false');
                        }
                    });
                    
                    currentIndex = index;
                    
                    // Reset transition flag after animation completes
                    setTimeout(() => {
                        isTransitioning = false;
                    }, 800);
                }

                // Next slide
                function nextSlide() {
                    if (!isTransitioning) {
                        showSlide(currentIndex + 1);
                    }
                }

                // Previous slide
                function prevSlide() {
                    if (!isTransitioning) {
                        showSlide(currentIndex - 1);
                    }
                }

                // Event listeners
                if (prevButton) {
                    prevButton.addEventListener('click', (e) => {
                        e.preventDefault();
                        prevSlide();
                        resetInterval();
                    });
                }

                if (nextButton) {
                    nextButton.addEventListener('click', (e) => {
                        e.preventDefault();
                        nextSlide();
                        resetInterval();
                    });
                }

                // Indicator clicks
                indicators.forEach((indicator, index) => {
                    indicator.addEventListener('click', () => {
                        if (!isTransitioning && index !== currentIndex) {
                            showSlide(index);
                            resetInterval();
                        }
                    });
                });

                // Auto-advance every 5 seconds
                function startInterval() {
                    if (interval) clearInterval(interval);
                    interval = setInterval(() => {
                        if (!isTransitioning) {
                            nextSlide();
                        }
                    }, 5000);
                }

                function resetInterval() {
                    if (interval) clearInterval(interval);
                    startInterval();
                }

                startInterval();

                // Pause on hover
                if (carousel) {
                    carousel.addEventListener('mouseenter', () => {
                        if (interval) clearInterval(interval);
                    });
                    
                    carousel.addEventListener('mouseleave', () => {
                        startInterval();
                    });
                }

                // Touch support for mobile
                let touchStartX = 0;
                let touchEndX = 0;
                
                carousel.addEventListener('touchstart', (e) => {
                    touchStartX = e.changedTouches[0].screenX;
                }, { passive: true });
                
                carousel.addEventListener('touchend', (e) => {
                    touchEndX = e.changedTouches[0].screenX;
                    if (touchEndX < touchStartX - 50) {
                        // Swipe left
                        nextSlide();
                        resetInterval();
                    } else if (touchEndX > touchStartX + 50) {
                        // Swipe right
                        prevSlide();
                        resetInterval();
                    }
                }, { passive: true });
                
                console.log('BHC Carousel: Initialized successfully');
            }

            // Run when DOM is ready
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initCarousel);
            } else {
                // DOM already loaded
                initCarousel();
            }
            
            // Also run after a short delay to ensure everything is loaded
            setTimeout(initCarousel, 100);
            
        })();
    </script>
</body>
</html>