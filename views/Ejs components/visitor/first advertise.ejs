<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eternity Care Services| Empowering Lives with Personalised Care</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Remixicon Icons -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.6s ease-in-out',
                        'slide-up': 'slideUp 0.6s ease-out',
                        'float': 'float 3s ease-in-out infinite',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        },
                        float: {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Theme transition */
        * {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
        }
        
        /* Hero overlay */
        .hero-overlay {
            background: linear-gradient(135deg, rgba(30, 64, 175, 0.85) 0%, rgba(37, 99, 235, 0.75) 50%, rgba(59, 130, 246, 0.7) 100%);
        }
        .dark .hero-overlay {
            background: linear-gradient(135deg, rgba(30, 58, 138, 0.9) 0%, rgba(30, 64, 175, 0.85) 50%, rgba(37, 99, 235, 0.8) 100%);
        }
        
        /* Card hover effects */
        .service-card {
            transition: all 0.3s ease;
        }
        .service-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
        
        /* Step card */
        .step-card {
            transition: all 0.3s ease;
        }
        .step-card:hover {
            transform: translateY(-5px);
            background-color: #f0f9ff;
        }
        .dark .step-card:hover {
            background-color: #1e3a8a20;
        }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen">

   <br>

    <!-- Hero Section with Unsplash Image -->
    <section class="relative w-full h-[600px] lg:h-[700px] overflow-hidden">
        <!-- Pexels Image: Caregiver with elderly person -->
        <img src="https://images.pexels.com/photos/6646917/pexels-photo-6646917.jpeg?auto=compress&cs=tinysrgb&w=1600" 
             alt="Compassionate care" 
             class="absolute inset-0 w-full h-full object-cover object-center"
             loading="lazy">
        <!-- Blue Gradient Overlay -->
        <div class="hero-overlay absolute inset-0"></div>
        
        <!-- Hero Content -->
        <div class="absolute inset-0 flex flex-col items-center justify-center text-center px-4">
            <div class="inline-flex items-center justify-center p-3 bg-white/20 backdrop-blur-sm rounded-full mb-6 animate-float">
                <i class="ri-heart-pulse-fill text-white text-4xl"></i>
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 drop-shadow-lg max-w-4xl animate-fade-in">
                Empowering Lives with <span class="text-yellow-300">Personalised Care</span>
            </h1>
            <div class="w-24 h-1 bg-white rounded-full mb-6"></div>
            <p class="text-white text-xl md:text-2xl max-w-3xl drop-shadow-md animate-slide-up">
                Choosing the right care provider is crucial for a fulfilling and independent life. At Eternity Care Services, we offer personalised care solutions tailored to individual needs.
            </p>
            <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-slide-up">
                <a href="#" class="bg-white text-blue-700 font-bold py-4 px-8 rounded-full shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center">
                    <i class="ri-phone-line mr-2"></i>
                    Free Consultation: 1300 513 309
                </a>
                <a href="#" class="bg-transparent border-2 border-white text-white font-bold py-4 px-8 rounded-full hover:bg-white/10 transition-all duration-300 flex items-center justify-center">
                    <i class="ri-calendar-line mr-2"></i>
                    Book a Consultation
                </a>
            </div>
        </div>
    </section>

    <!-- Comprehensive Services Section -->
    <section class="py-16 md:py-20 bg-white dark:bg-gray-800">
        <div class="container mx-auto px-4">
            <div class="max-w-4xl mx-auto text-center mb-12">
                <div class="inline-flex items-center justify-center p-2 bg-blue-100 dark:bg-blue-900/30 rounded-full mb-6">
                    <i class="ri-service-line text-blue-600 dark:text-blue-400 text-2xl mx-2"></i>
                </div>
                <h2 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-white mb-4">
                    Comprehensive Services <span class="text-blue-600 dark:text-blue-400">Tailored to Your Needs</span>
                </h2>
                <p class="text-gray-600 dark:text-gray-300 text-lg">
                    At Eternity Care Services, we understand that every individual has unique care requirements. Our range of personalised services supports independent living, from long-term care to short-term respite and post-hospital recovery. We create bespoke care plans that prioritise your comfort, security, and overall well-being.
                </p>
            </div>

            <!-- Stats Row -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
                <div class="text-center">
                    <div class="text-3xl md:text-4xl font-bold text-blue-600 dark:text-blue-400">500+</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">Clients Supported</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl md:text-4xl font-bold text-blue-600 dark:text-blue-400">15+</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">Years Experience</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl md:text-4xl font-bold text-blue-600 dark:text-blue-400">50+</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">Dedicated Carers</div>
                </div>
                <div class="text-center">
                    <div class="text-3xl md:text-4xl font-bold text-blue-600 dark:text-blue-400">100%</div>
                    <div class="text-sm text-gray-600 dark:text-gray-400">Person-Centred</div>
                </div>
            </div>
        </div>
    </section>

    <script>
        // Theme functionality
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');
        const themeText = document.getElementById('themeText');
        
        // Check for saved theme preference or use default
        const savedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const currentTheme = savedTheme || (prefersDark ? 'dark' : 'light');
        
        // Apply theme on page load
        if (currentTheme === 'dark') {
            document.documentElement.classList.add('dark');
            updateThemeUI('dark');
        } else {
            document.documentElement.classList.remove('dark');
            updateThemeUI('light');
        }
        
        // Update theme UI elements
        function updateThemeUI(theme) {
            if (themeIcon && themeText) {
                if (theme === 'dark') {
                    themeIcon.className = 'ri-sun-line mr-2 text-lg';
                    themeText.textContent = 'Light Mode';
                } else {
                    themeIcon.className = 'ri-moon-line mr-2 text-lg';
                    themeText.textContent = 'Dark Mode';
                }
            }
        }
        
        // Toggle theme function
        function toggleTheme() {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
                updateThemeUI('light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                updateThemeUI('dark');
            }
        }
        
        // Add event listener for theme toggle
        if (themeToggle) {
            themeToggle.addEventListener('click', toggleTheme);
        }
        
        // Listen for system theme changes
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
            if (!localStorage.getItem('theme')) {
                if (e.matches) {
                    document.documentElement.classList.add('dark');
                    updateThemeUI('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                    updateThemeUI('light');
                }
            }
        });
    </script>
</body>
</html>