<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Free Consultation | Eternity Care Services</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Remixicon Icons -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff',
                            100: '#dbeafe',
                            200: '#bfdbfe',
                            300: '#93c5fd',
                            400: '#60a5fa',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                            800: '#1e40af',
                            900: '#1e3a8a',
                        }
                    },
                    animation: {
                        'fade-in': 'fadeIn 0.6s ease-in-out',
                        'pulse-slow': 'pulse 3s infinite',
                        'slide-up': 'slideUp 0.5s ease-out',
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        },
                        slideUp: {
                            '0%': { transform: 'translateY(20px)', opacity: '0' },
                            '100%': { transform: 'translateY(0)', opacity: '1' },
                        }
                    },
                    screens: {
                        'xs': '475px',
                        'sm': '640px',
                        'md': '768px',
                        'lg': '1024px',
                        'xl': '1280px',
                        '2xl': '1536px',
                        '3xl': '1920px',
                    }
                }
            }
        }
    </script>
    <style>
        /* Theme transition */
        * {
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
        }
        
        /* Gradient background with animation */
        .consultation-bg {
            background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
            background-size: 200% 200%;
            animation: gradientShift 15s ease infinite;
        }
        .dark .consultation-bg {
            background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 100%);
            background-size: 200% 200%;
            animation: gradientShift 15s ease infinite;
        }
        
        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }
        
        /* Custom container max-width for large screens */
        .container-custom {
            max-width: 1440px;
            margin-left: auto;
            margin-right: auto;
        }
        
        @media (min-width: 1920px) {
            .container-custom {
                max-width: 1600px;
            }
        }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen flex items-center justify-center p-4 md:p-6 lg:p-8 xl:p-10">

    <!-- Theme Toggle Button -->
    <div class="absolute top-4 right-4 sm:top-6 sm:right-6 md:top-8 md:right-8 z-50">
        <button id="themeToggle" class="flex items-center px-3 py-2 sm:px-4 sm:py-2.5 rounded-full bg-white/90 dark:bg-gray-800/90 backdrop-blur-sm text-gray-700 dark:text-gray-200 hover:bg-white dark:hover:bg-gray-700 shadow-lg hover:shadow-xl transition-all duration-300 border border-gray-200 dark:border-gray-700 text-sm sm:text-base">
            <i id="themeIcon" class="ri-moon-line mr-1.5 sm:mr-2 text-base sm:text-lg"></i>
            <span id="themeText" class="hidden xs:inline">Dark Mode</span>
        </button>
    </div>

    <!-- Main Container -->
    <div class="w-full container-custom px-0 sm:px-4 md:px-6 lg:px-8 xl:px-12">
        <!-- Free Consultation Banner -->
        <section class="consultation-bg py-8 sm:py-10 md:py-12 lg:py-16 xl:py-20 px-4 sm:px-8 md:px-12 lg:px-16 xl:px-20 rounded-2xl sm:rounded-3xl lg:rounded-4xl shadow-xl sm:shadow-2xl lg:shadow-3xl w-full animate-slide-up">
            
            <!-- Decorative Elements for Large Screens -->
            <div class="relative">
                <!-- Floating circles decoration -->
                <div class="absolute top-0 left-0 w-32 h-32 sm:w-40 sm:h-40 md:w-48 md:h-48 lg:w-56 lg:h-56 xl:w-64 xl:h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2 hidden lg:block"></div>
                <div class="absolute bottom-0 right-0 w-40 h-40 sm:w-48 sm:h-48 md:w-56 md:h-56 lg:w-64 lg:h-64 xl:w-72 xl:h-72 bg-white/5 rounded-full translate-x-1/2 translate-y-1/2 hidden lg:block"></div>
                
                <!-- Content -->
                <div class="text-center text-white relative z-10 max-w-7xl mx-auto">
                    
                    <!-- Icon with responsive sizing -->
                    <div class="inline-flex items-center justify-center p-3 sm:p-4 md:p-5 lg:p-6 bg-white/20 backdrop-blur-sm rounded-full mb-4 sm:mb-5 md:mb-6 lg:mb-8 shadow-xl">
                        <i class="ri-phone-line text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl"></i>
                    </div>
                    
                    <!-- Heading with responsive text sizes -->
                    <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-bold mb-3 sm:mb-4 md:mb-5 lg:mb-6 px-2">
                        Start with a <span class="text-yellow-300">Free Consultation</span>
                    </h2>
                    
                    <!-- Description with optimal line length -->
                    <p class="text-base sm:text-lg md:text-xl lg:text-2xl xl:text-3xl mb-5 sm:mb-6 md:mb-7 lg:mb-8 text-white/90 max-w-3xl lg:max-w-4xl xl:max-w-5xl mx-auto px-4 sm:px-6 leading-relaxed">
                        Take advantage of our complimentary, obligation-free consultation to explore your in-home care needs. We'll take the time to understand your situation and recommend tailored care solutions designed just for you.
                    </p>
                    
                    <!-- CTA Button with responsive sizing -->
                    <a href="tel:1300513309" class="inline-flex items-center bg-white text-blue-700 font-bold py-3 sm:py-4 md:py-5 px-6 sm:px-8 md:px-10 lg:px-12 xl:px-14 rounded-full shadow-xl hover:shadow-2xl transition-all duration-300 text-base sm:text-lg md:text-xl lg:text-2xl xl:text-3xl group hover:scale-105">
                        <i class="ri-phone-line mr-2 sm:mr-3 text-lg sm:text-xl md:text-2xl lg:text-3xl group-hover:animate-pulse"></i>
                        Free Consultation: <span class="ml-2 font-extrabold">1300 513 309</span>
                    </a>
                    
                    <!-- Additional Info for Large Screens -->
                    <div class="mt-8 lg:mt-12 grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 max-w-3xl mx-auto text-white/80 text-sm sm:text-base">
                        <div class="flex items-center justify-center gap-2">
                            <i class="ri-time-line text-lg sm:text-xl"></i>
                            <span>24/7 Availability</span>
                        </div>
                        <div class="flex items-center justify-center gap-2">
                            <i class="ri-customer-service-line text-lg sm:text-xl"></i>
                            <span>Expert Care Advisors</span>
                        </div>
                        <div class="flex items-center justify-center gap-2">
                            <i class="ri-heart-line text-lg sm:text-xl"></i>
                            <span>No Obligation</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        
        <!-- Trust Badges for Large Screens -->
        <div class="mt-8 lg:mt-12 flex flex-wrap items-center justify-center gap-6 lg:gap-10 text-gray-600 dark:text-gray-400 text-sm lg:text-base">
            <div class="flex items-center gap-2">
                <i class="ri-shield-check-line text-green-500 text-xl lg:text-2xl"></i>
                <span>Licensed & Insured</span>
            </div>
            <div class="flex items-center gap-2">
                <i class="ri-star-line text-yellow-500 text-xl lg:text-2xl"></i>
                <span>5-Star Rated</span>
            </div>
            <div class="flex items-center gap-2">
                <i class="ri-team-line text-blue-500 text-xl lg:text-2xl"></i>
                <span>1000+ Happy Clients</span>
            </div>
        </div>
    </div>

    <script>
        // Theme functionality
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');
        const themeText = document.getElementById('themeText');
        
        // Check for saved theme preference or use default
        const savedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const currentTheme = savedTheme || (prefersDark ? 'dark' : 'light');
        
        // Apply theme on page load
        if (currentTheme === 'dark') {
            document.documentElement.classList.add('dark');
            updateThemeUI('dark');
        } else {
            document.documentElement.classList.remove('dark');
            updateThemeUI('light');
        }
        
        function updateThemeUI(theme) {
            if (themeIcon && themeText) {
                themeIcon.className = theme === 'dark' ? 'ri-sun-line mr-1.5 sm:mr-2 text-base sm:text-lg' : 'ri-moon-line mr-1.5 sm:mr-2 text-base sm:text-lg';
                themeText.textContent = theme === 'dark' ? 'Light Mode' : 'Dark Mode';
            }
        }
        
        themeToggle.addEventListener('click', () => {
            if (document.documentElement.classList.contains('dark')) {
                document.documentElement.classList.remove('dark');
                localStorage.setItem('theme', 'light');
                updateThemeUI('light');
            } else {
                document.documentElement.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                updateThemeUI('dark');
            }
        });

        // Optional: Add smooth scroll behavior
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
    </script>
</body>
</html>